{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Backend (nodemon)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "${workspaceFolder}/express-project/node_modules/.bin/nodemon",
      "program": "${workspaceFolder}/express-project/app.js",
      "cwd": "${workspaceFolder}/express-project",
      "restart": true,
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Debug Backend (node, no restart)",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/express-project/app.js",
      "cwd": "${workspaceFolder}/express-project",
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Attach to Process",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
